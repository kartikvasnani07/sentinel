<Window x:Class="AssistantDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AssistantDesktop"
        Title="Assistant"
        Width="1100"
        Height="720"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ChipButton">
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBlock Text="Assistant" FontSize="20" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="10" Padding="8,2" Margin="12,0,0,0">
                    <TextBlock Text="Local" Foreground="{StaticResource AccentBrush}" FontSize="12"/>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <TextBlock Text="Status:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextPrimaryBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="What can I help with?" FontSize="30" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,10,0,12"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <Button Style="{StaticResource ChipButton}" Content="Search" Click="Search_Click"/>
                <Button Style="{StaticResource ChipButton}" Content="Open App" Click="OpenApp_Click"/>
                <Button Style="{StaticResource ChipButton}" Content="System Settings" Click="SystemSettings_Click"/>
                <Button Style="{StaticResource ChipButton}" Content="Summarize" Click="Summarize_Click"/>
            </StackPanel>

            <Border Grid.Row="2" Margin="0,24,0,0" Background="{StaticResource CardBackgroundBrush}" CornerRadius="18" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:ChatMessage}">
                                    <Border Margin="0,8" Padding="14" CornerRadius="16" Background="{StaticResource AppBackgroundBrush}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="Background" Value="#13151C"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter Property="Background" Value="#1D2835"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" MaxWidth="640"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding PinnedItems}" Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1D1F28" CornerRadius="12" Padding="10" Margin="0,6,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}" Foreground="{StaticResource TextSecondaryBrush}" Width="640" TextTrimming="CharacterEllipsis"/>
                                        <Button Content="Remove" Tag="{Binding}" Margin="10,0,0,0" Click="RemovePin_Click"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
                        <Button x:Name="PinButton" Content="Pin" Width="60" Height="38" Click="Pin_Click">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Pin File" Click="PinFile_Click"/>
                                    <MenuItem Header="Pin Folder" Click="PinFolder_Click"/>
                                    <MenuItem Header="Clear Pins" Click="ClearPins_Click"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <ComboBox x:Name="ModelSelector"
                                  Width="180"
                                  Height="38"
                                  Margin="10,0,0,0"
                                  ItemsSource="{Binding ModelOptions}"
                                  SelectedItem="{Binding SelectedModelOption}"
                                  DisplayMemberPath="Label"/>
                        <ComboBox x:Name="AccessSelector"
                                  Width="140"
                                  Height="38"
                                  Margin="10,0,0,0"
                                  ItemsSource="{Binding AccessOptions}"
                                  SelectedItem="{Binding SelectedAccessOption}"
                                  DisplayMemberPath="Label"/>
                        <TextBox x:Name="InputBox"
                                 Width="520"
                                 Height="46"
                                 Margin="10,0,0,0"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Background="{StaticResource AppBackgroundBrush}"
                                 BorderBrush="{StaticResource CardBorderBrush}"
                                 BorderThickness="1"
                                 Padding="14,6"
                                 KeyDown="InputBox_OnKeyDown"
                                 Text=""/>
                        <Button Content="Send"
                                Width="90"
                                Height="46"
                                Margin="12,0,0,0"
                                Background="{StaticResource AccentBrush}"
                                Foreground="#0B1118"
                                BorderThickness="0"
                                Click="Send_Click"/>
                        <Button Content="Mic"
                                Width="70"
                                Height="46"
                                Margin="12,0,0,0"
                                Background="#1F2431"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
